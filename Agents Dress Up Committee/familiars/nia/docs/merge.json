{
  "version": 1,
  "notes": "Declarative prompt merge map for Nia.",
  "first_prompt": {
    "static_files": [
      "docs/agent.md",
      "docs/personality.md",
      "docs/coding.md",
      "meta.json",
      "docs/preferences.md",
      "docs/memories.md",
      "profile.json",
      "docs/agents/chronos.md"
    ],
    "dynamic_blocks": [
      "current_date_time",
      "current_state",
      "focus_cycle_status_and_guidance",
      "agents_policy_summary",
      "conversation_history",
      "memory_snippet_if_enabled"
    ]
  },
  "per_message": {
    "static_files": [
      "docs/preferences.md",
      "docs/memories.md",
      "profile.json"
    ],
    "dynamic_blocks": [
      "current_date_time",
      "current_state",
      "focus_cycle_status_and_guidance",
      "agents_policy_summary",
      "conversation_history",
      "memory_snippet_if_enabled"
    ]
  },
  "optional": {
    "chronos_mode": {
      "config": "docs/chronos-merge.json",
      "enabled_by": ["env:ADUC_EXTERNAL_CONTEXT_FILE"]
    }
  }
}
