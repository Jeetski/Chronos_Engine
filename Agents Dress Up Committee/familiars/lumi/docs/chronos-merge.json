    "docs/guides/conditions_cookbook.md",
    "docs/guides/common_workflows.md",
    "docs/guides/dashboard.md",
    "docs/guides/cockpit.md",
    "docs/agents/agents.md",
    "docs/guides/settings.md",
    "docs/dev/sequence.md"
  ]
}
