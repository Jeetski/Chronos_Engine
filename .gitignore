# Python caches and build artifacts
__pycache__/
*.py[cod]
*.pyd
*.so
*.egg-info/
build/
dist/
.cache/
.mypy_cache/
.pytype/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/
.env
node_modules/

# Editors/OS
.DS_Store
Thumbs.db
.idea/
.vscode/

# Root debug files (exclude from repo)
debug_*

# Local website and release artifacts (engine repo shouldn't include these)
Website/
_site/
Releases/
*.zip

# Dashboard generated bundles
Utilities/Dashboard/generated/*

# Temp/debug artifacts
Temp/
tmp_*.js
debug_*.txt

# Project notes/backups
IDEAS/
META/
META.md
backup/

# User data policy:
# - Keep directory structure visible via .gitkeep placeholders.
# - Track shared config/code/examples.
# - Ignore personal runtime/content files by default.
User/**
!User/
!User/**/
!User/**/.gitkeep
!User/Settings/**
!User/Scripts/**
!User/Examples/**
!User/**/*_example.yml
# Local credential-bearing settings
User/Settings/link_settings.yml

# Generated registries/logs
Registry/*.json
logs/*.log

# ADUC runtime state + memories (local/user-specific)
Agents Dress Up Committee/familiars/*/state.json
Agents Dress Up Committee/familiars/*/milestones.json
Agents Dress Up Committee/familiars/*/memory.json
Agents Dress Up Committee/familiars/*/docs/memories.md
# ADUC local art assets kept out of the Chronos repo
Agents Dress Up Committee/familiars/*/avatar/*.png
Agents Dress Up Committee/familiars/*/avatar/**/*.png
Agents Dress Up Committee/familiars/*/locations/*.png
Agents Dress Up Committee/familiars/*/locations/**/*.png
Agents Dress Up Committee/familiars/*/backgrounds/*.png
Agents Dress Up Committee/familiars/*/backgrounds/**/*.png

# Playwright CLI local artifacts
.playwright-cli/

# Pytest cache
.pytest_cache/

# Thoughtforms sidecar frontend artifacts
thoughtforms/app/dist/
